\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Visual representation of the time dilation factor \( \frac  {d\tau }{dt} \) as a function of both the orbital velocity \( v_\text  {orb} \) and the gravitational æther inflow velocity \( v_g \). The surface shows how both contributions — inertial and gravitationally derived æther flow — together result in a total slowing down of the clock. The hyperbolic curvature of the surface reflects the combined Lorentz and Schwarzschild dilation as described in equations (5) and (6).}}{14}{figure.caption.25}\protected@file@percent }
\newlabel{fig:TimeDialationCombined}{{8}{14}{Visual representation of the time dilation factor \( \frac {d\tau }{dt} \) as a function of both the orbital velocity \( v_\text {orb} \) and the gravitational æther inflow velocity \( v_g \). The surface shows how both contributions — inertial and gravitationally derived æther flow — together result in a total slowing down of the clock. The hyperbolic curvature of the surface reflects the combined Lorentz and Schwarzschild dilation as described in equations (5) and (6)}{figure.caption.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Æther flow accelerates towards $r_s$, where the observed clock rotation becomes zero. Freezing of time at the event horizon $r = r_s$: the Æther flow approaches~$c$, causing $\omega _{\mathrm  {obs}} \to 0$. On the right, the corresponding decrease in $\frac  {d\tau }{dt}$ as a function of distance is shown.}}{15}{figure.caption.27}\protected@file@percent }
\newlabel{fig:HorizonTijdsbevriezing}{{9}{15}{Æther flow accelerates towards $r_s$, where the observed clock rotation becomes zero. Freezing of time at the event horizon $r = r_s$: the Æther flow approaches~$c$, causing $\omega _{\mathrm {obs}} \to 0$. On the right, the corresponding decrease in $\frac {d\tau }{dt}$ as a function of distance is shown}{figure.caption.27}{}}
