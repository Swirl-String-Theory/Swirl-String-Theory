+            \rhoE(x) &= \frac12 \, \rhoF(x) \, \norm{\vswirl(x)}^2, \\
+            \rhoM(x) &= \frac{\rhoE(x)}{c^2}, \\
+            \SwirlClock(x) &= \sqrt{1 - \frac{\norm{\vswirl(x)}^2}{c^2}}.
