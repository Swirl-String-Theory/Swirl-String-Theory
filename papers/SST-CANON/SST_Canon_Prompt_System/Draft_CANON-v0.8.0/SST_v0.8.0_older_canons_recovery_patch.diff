+        \begin{align}
+            \Lambda_{\mathrm{SST}} = 4\pi \, \rho_{\mathrm{core}} \, v_{\swirlarrow}^{2} \, r_c^{4}
+            \label{eq:lambda_sst}
+        \end{align}
+        with dimensions
+        \begin{align}
+            [\Lambda_{\mathrm{SST}}] = \mathrm{J\,m} = \mathrm{N\,m^2}.
+        \end{align}
+        
+        A finite-core bridge potential is then
+        \begin{align}
+            V_{\mathrm{soft}}(r) = -\frac{\Lambda_{\mathrm{SST}}}{\sqrt{r^2+r_c^2}}
